{% set integrationMode = config("KlaviyoSiteEventTracking.tracking.integrationMode")|default("plugin") %}
{% set publicApiKey = config("KlaviyoSiteEventTracking.tracking.publicApiKey")|default("") %}
{% set truthyValues = ["1", "true", "on", "yes"] %}

{% set enableDebugLoggingConfig = config("KlaviyoSiteEventTracking.tracking.enableDebugLogging") %}
{% set enableDebugLogging = enableDebugLoggingConfig is same as(true)
  or (enableDebugLoggingConfig|string|lower in truthyValues) %}

{% set logIdentifyCallsConfig = config("KlaviyoSiteEventTracking.tracking.logIdentifyCalls") %}
{% set logIdentifyCalls = logIdentifyCallsConfig is same as(true)
  or (logIdentifyCallsConfig|string|lower in truthyValues) %}

{% set logTrackCallsConfig = config("KlaviyoSiteEventTracking.tracking.logTrackCalls") %}
{% set logTrackCalls = logTrackCallsConfig is same as(true)
  or (logTrackCallsConfig|string|lower in truthyValues) %}

{% set logErrorsOnlyConfig = config("KlaviyoSiteEventTracking.tracking.logErrorsOnly") %}
{% set logErrorsOnly = logErrorsOnlyConfig is same as(true)
  or (logErrorsOnlyConfig|string|lower in truthyValues) %}

<script>
  window.KlaviyoSiteEventTracking = window.KlaviyoSiteEventTracking || {};
  window.KlaviyoSiteEventTracking.integrationMode = "{{ integrationMode|e('js') }}";
  window.KlaviyoSiteEventTracking.publicApiKey = "{{ publicApiKey|e('js') }}";
  window.KlaviyoSiteEventTracking.enableDebugLogging = {{ enableDebugLogging ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logIdentifyCalls = {{ logIdentifyCalls ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logTrackCalls = {{ logTrackCalls ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logErrorsOnly = {{ logErrorsOnly ? 'true' : 'false' }};
</script>
<script src="{{ plugin_path('KlaviyoSiteEventTracking') }}/js/klaviyo-tracking-placeholder.js"></script>
