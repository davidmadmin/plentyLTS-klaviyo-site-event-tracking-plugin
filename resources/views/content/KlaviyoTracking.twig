{% set integrationMode = config("KlaviyoSiteEventTracking.tracking.integrationMode")|default("plugin") %}
{% set publicApiKey = config("KlaviyoSiteEventTracking.tracking.publicApiKey")|default("") %}
{% set checkboxEnabledValues = [1, "1", true, "true", "on"] %}
{% set checkboxDisabledValues = [0, "0", false, "false", ""] %}

{% set enableDebugLoggingRaw = config("KlaviyoSiteEventTracking.tracking.enableDebugLogging")|default("") %}
{% set enableDebugLogging = enableDebugLoggingRaw in checkboxEnabledValues ? true : (enableDebugLoggingRaw in checkboxDisabledValues ? false : false) %}

{% set logPluginHeartbeatRaw = config("KlaviyoSiteEventTracking.tracking.logPluginHeartbeat")|default("") %}
{% set logPluginHeartbeat = logPluginHeartbeatRaw in checkboxEnabledValues ? true : (logPluginHeartbeatRaw in checkboxDisabledValues ? false : false) %}

{% set logIdentifyCallsRaw = config("KlaviyoSiteEventTracking.tracking.logIdentifyCalls")|default("") %}
{% set logIdentifyCalls = logIdentifyCallsRaw in checkboxEnabledValues ? true : (logIdentifyCallsRaw in checkboxDisabledValues ? false : false) %}

{% set logTrackCallsRaw = config("KlaviyoSiteEventTracking.tracking.logTrackCalls")|default("") %}
{% set logTrackCalls = logTrackCallsRaw in checkboxEnabledValues ? true : (logTrackCallsRaw in checkboxDisabledValues ? false : false) %}

{% set logErrorsOnlyRaw = config("KlaviyoSiteEventTracking.tracking.logErrorsOnly")|default("") %}
{% set logErrorsOnly = logErrorsOnlyRaw in checkboxEnabledValues ? true : (logErrorsOnlyRaw in checkboxDisabledValues ? false : false) %}

<script>
  window.KlaviyoSiteEventTracking = window.KlaviyoSiteEventTracking || {};
  window.KlaviyoSiteEventTracking.integrationMode = "{{ integrationMode|e('js') }}";
  window.KlaviyoSiteEventTracking.publicApiKey = "{{ publicApiKey|e('js') }}";
  window.KlaviyoSiteEventTracking.enableDebugLogging = {{ enableDebugLogging ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logPluginHeartbeat = {{ logPluginHeartbeat ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logIdentifyCalls = {{ logIdentifyCalls ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logTrackCalls = {{ logTrackCalls ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logErrorsOnly = {{ logErrorsOnly ? 'true' : 'false' }};
</script>
<script src="{{ plugin_path('KlaviyoSiteEventTracking') }}/js/klaviyo-tracking-placeholder.js"></script>
