{% set integrationMode = config("KlaviyoSiteEventTracking.tracking.integrationMode")|default("plugin") %}
{% set publicApiKey = config("KlaviyoSiteEventTracking.tracking.publicApiKey")|default("") %}
{% set checkboxEnabledValues = ["1", "true", "on"] %}
{% set checkboxDisabledValues = ["0", "false", ""] %}

{% set logPluginHeartbeatRaw = config("KlaviyoSiteEventTracking.tracking.logPluginHeartbeat")|default("") %}
{% set logPluginHeartbeatNormalized = (logPluginHeartbeatRaw ~ "")|trim|lower %}
{% set logPluginHeartbeat = (logPluginHeartbeatRaw is same as(true)) or (logPluginHeartbeatRaw is same as(1)) or (logPluginHeartbeatNormalized in checkboxEnabledValues) ? true : ((logPluginHeartbeatRaw is same as(false)) or (logPluginHeartbeatRaw is same as(0)) or (logPluginHeartbeatNormalized in checkboxDisabledValues) ? false : false) %}

{% set logIdentifyEventDebugRaw = config("KlaviyoSiteEventTracking.tracking.logIdentifyEventDebug")|default("") %}
{% set logIdentifyEventDebugNormalized = (logIdentifyEventDebugRaw ~ "")|trim|lower %}
{% set logIdentifyEventDebug = (logIdentifyEventDebugRaw is same as(true)) or (logIdentifyEventDebugRaw is same as(1)) or (logIdentifyEventDebugNormalized in checkboxEnabledValues) ? true : ((logIdentifyEventDebugRaw is same as(false)) or (logIdentifyEventDebugRaw is same as(0)) or (logIdentifyEventDebugNormalized in checkboxDisabledValues) ? false : false) %}

{% set logViewedProductEventDebugRaw = config("KlaviyoSiteEventTracking.tracking.logViewedProductEventDebug")|default("") %}
{% set logViewedProductEventDebugNormalized = (logViewedProductEventDebugRaw ~ "")|trim|lower %}
{% set logViewedProductEventDebug = (logViewedProductEventDebugRaw is same as(true)) or (logViewedProductEventDebugRaw is same as(1)) or (logViewedProductEventDebugNormalized in checkboxEnabledValues) ? true : ((logViewedProductEventDebugRaw is same as(false)) or (logViewedProductEventDebugRaw is same as(0)) or (logViewedProductEventDebugNormalized in checkboxDisabledValues) ? false : false) %}

{% set logAddedToCartEventDebugRaw = config("KlaviyoSiteEventTracking.tracking.logAddedToCartEventDebug")|default("") %}
{% set logAddedToCartEventDebugNormalized = (logAddedToCartEventDebugRaw ~ "")|trim|lower %}
{% set logAddedToCartEventDebug = (logAddedToCartEventDebugRaw is same as(true)) or (logAddedToCartEventDebugRaw is same as(1)) or (logAddedToCartEventDebugNormalized in checkboxEnabledValues) ? true : ((logAddedToCartEventDebugRaw is same as(false)) or (logAddedToCartEventDebugRaw is same as(0)) or (logAddedToCartEventDebugNormalized in checkboxDisabledValues) ? false : false) %}

{% set debugIdentifyEmailOverride = config("KlaviyoSiteEventTracking.tracking.debugIdentifyEmailOverride")|default("") %}
{% set enableViewedProductEventRaw = config("KlaviyoSiteEventTracking.tracking.enableViewedProductEvent")|default(null) %}
{% set enableViewedProductEventNormalized = (enableViewedProductEventRaw ~ "")|trim|lower %}
{% set enableViewedProductEvent = (enableViewedProductEventRaw is same as(true)) or (enableViewedProductEventRaw is same as(1)) or (enableViewedProductEventNormalized in checkboxEnabledValues) ? true : ((enableViewedProductEventRaw is same as(false)) or (enableViewedProductEventRaw is same as(0)) or (enableViewedProductEventNormalized in checkboxDisabledValues) ? false : true) %}


{% set enableAddedToCartEventRaw = config("KlaviyoSiteEventTracking.tracking.enableAddedToCartEvent")|default(null) %}
{% set enableAddedToCartEventNormalized = (enableAddedToCartEventRaw ~ "")|trim|lower %}
{% set enableAddedToCartEvent = (enableAddedToCartEventRaw is same as(true)) or (enableAddedToCartEventRaw is same as(1)) or (enableAddedToCartEventNormalized in checkboxEnabledValues) ? true : ((enableAddedToCartEventRaw is same as(false)) or (enableAddedToCartEventRaw is same as(0)) or (enableAddedToCartEventNormalized in checkboxDisabledValues) ? false : true) %}

<script>
  window.KlaviyoSiteEventTracking = window.KlaviyoSiteEventTracking || {};
  window.KlaviyoSiteEventTracking.integrationMode = "{{ integrationMode|e('js') }}";
  window.KlaviyoSiteEventTracking.publicApiKey = "{{ publicApiKey|e('js') }}";
  window.KlaviyoSiteEventTracking.logPluginHeartbeat = {{ logPluginHeartbeat ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logIdentifyEventDebug = {{ logIdentifyEventDebug ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.debugIdentifyEmailOverride = "{{ debugIdentifyEmailOverride|e('js') }}";
  window.KlaviyoSiteEventTracking.logViewedProductEventDebug = {{ logViewedProductEventDebug ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logAddedToCartEventDebug = {{ logAddedToCartEventDebug ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.enableViewedProductEvent = {{ enableViewedProductEvent ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.enableAddedToCartEvent = {{ enableAddedToCartEvent ? 'true' : 'false' }};
</script>
<script src="{{ plugin_path('KlaviyoSiteEventTracking') }}/js/klaviyo-site-event-tracking.js"></script>
