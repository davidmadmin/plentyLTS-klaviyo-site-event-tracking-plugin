{% set integrationMode = config("KlaviyoSiteEventTracking.tracking.integrationMode")|default("plugin") %}
{% set publicApiKey = config("KlaviyoSiteEventTracking.tracking.publicApiKey")|default("") %}
{% set checkboxEnabledValues = ["1", "true", "on"] %}
{% set checkboxDisabledValues = ["0", "false", ""] %}

{% set enableDebugLoggingRaw = config("KlaviyoSiteEventTracking.tracking.enableDebugLogging")|default("") %}
{% set enableDebugLoggingNormalized = (enableDebugLoggingRaw ~ "")|trim|lower %}
{% set enableDebugLogging = (enableDebugLoggingRaw is same as(true)) or (enableDebugLoggingRaw is same as(1)) or (enableDebugLoggingNormalized in checkboxEnabledValues) ? true : ((enableDebugLoggingRaw is same as(false)) or (enableDebugLoggingRaw is same as(0)) or (enableDebugLoggingNormalized in checkboxDisabledValues) ? false : false) %}

{% set logPluginHeartbeatRaw = config("KlaviyoSiteEventTracking.tracking.logPluginHeartbeat")|default("") %}
{% set logPluginHeartbeatNormalized = (logPluginHeartbeatRaw ~ "")|trim|lower %}
{% set logPluginHeartbeat = (logPluginHeartbeatRaw is same as(true)) or (logPluginHeartbeatRaw is same as(1)) or (logPluginHeartbeatNormalized in checkboxEnabledValues) ? true : ((logPluginHeartbeatRaw is same as(false)) or (logPluginHeartbeatRaw is same as(0)) or (logPluginHeartbeatNormalized in checkboxDisabledValues) ? false : false) %}

{% set logIdentifyCallsRaw = config("KlaviyoSiteEventTracking.tracking.logIdentifyCalls")|default("") %}
{% set logIdentifyCallsNormalized = (logIdentifyCallsRaw ~ "")|trim|lower %}
{% set logIdentifyCalls = (logIdentifyCallsRaw is same as(true)) or (logIdentifyCallsRaw is same as(1)) or (logIdentifyCallsNormalized in checkboxEnabledValues) ? true : ((logIdentifyCallsRaw is same as(false)) or (logIdentifyCallsRaw is same as(0)) or (logIdentifyCallsNormalized in checkboxDisabledValues) ? false : false) %}

{% set logTrackCallsRaw = config("KlaviyoSiteEventTracking.tracking.logTrackCalls")|default("") %}
{% set logTrackCallsNormalized = (logTrackCallsRaw ~ "")|trim|lower %}
{% set logTrackCalls = (logTrackCallsRaw is same as(true)) or (logTrackCallsRaw is same as(1)) or (logTrackCallsNormalized in checkboxEnabledValues) ? true : ((logTrackCallsRaw is same as(false)) or (logTrackCallsRaw is same as(0)) or (logTrackCallsNormalized in checkboxDisabledValues) ? false : false) %}

{% set logErrorsOnlyRaw = config("KlaviyoSiteEventTracking.tracking.logErrorsOnly")|default("") %}
{% set logErrorsOnlyNormalized = (logErrorsOnlyRaw ~ "")|trim|lower %}
{% set logErrorsOnly = (logErrorsOnlyRaw is same as(true)) or (logErrorsOnlyRaw is same as(1)) or (logErrorsOnlyNormalized in checkboxEnabledValues) ? true : ((logErrorsOnlyRaw is same as(false)) or (logErrorsOnlyRaw is same as(0)) or (logErrorsOnlyNormalized in checkboxDisabledValues) ? false : false) %}

{% set enableViewedProductEventRaw = config("KlaviyoSiteEventTracking.tracking.enableViewedProductEvent")|default(null) %}
{% set enableViewedProductEventNormalized = (enableViewedProductEventRaw ~ "")|trim|lower %}
{% set enableViewedProductEvent = (enableViewedProductEventRaw is same as(true)) or (enableViewedProductEventRaw is same as(1)) or (enableViewedProductEventNormalized in checkboxEnabledValues) ? true : ((enableViewedProductEventRaw is same as(false)) or (enableViewedProductEventRaw is same as(0)) or (enableViewedProductEventNormalized in checkboxDisabledValues) ? false : true) %}

<script>
  window.KlaviyoSiteEventTracking = window.KlaviyoSiteEventTracking || {};
  window.KlaviyoSiteEventTracking.integrationMode = "{{ integrationMode|e('js') }}";
  window.KlaviyoSiteEventTracking.publicApiKey = "{{ publicApiKey|e('js') }}";
  window.KlaviyoSiteEventTracking.enableDebugLogging = {{ enableDebugLogging ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logPluginHeartbeat = {{ logPluginHeartbeat ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logIdentifyCalls = {{ logIdentifyCalls ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logTrackCalls = {{ logTrackCalls ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.logErrorsOnly = {{ logErrorsOnly ? 'true' : 'false' }};
  window.KlaviyoSiteEventTracking.enableViewedProductEvent = {{ enableViewedProductEvent ? 'true' : 'false' }};
</script>
<script src="{{ plugin_path('KlaviyoSiteEventTracking') }}/js/klaviyo-site-event-tracking.js"></script>
